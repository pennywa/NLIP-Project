# Angel Filter — environment variables
# Copy this file to .env and fill in your keys.
# Never commit .env — it is gitignored.

# --- AI Providers (enable at least one) ---

# Google Gemini — free tier at aistudio.google.com
GEMINI_API_KEY=

# OpenAI — free trial credits at platform.openai.com
OPENAI_API_KEY=

# IBM WatsonX — free tier at cloud.ibm.com (needs both values)
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_REGION=us-east
WATSONX_MODEL=ibm/granite-13b-instruct-v2

# Ollama — runs locally, no key needed, just set the model name
# Run: ollama pull llama3.2
OLLAMA_MODEL=llama3.2:latest

# --- Optional ---

# Brave Search — 2,000 free queries/month at api.search.brave.com
BRAVE_API_KEY=

# Override Ollama server URL if not running on localhost
# OLLAMA_URL=http://localhost:11434

# Override default models
# GEMINI_MODEL=gemini-2.5-flash
# OPENAI_MODEL=gpt-4o-mini
